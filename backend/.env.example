# 服务
PORT=3000
NODE_ENV=development
CORS_ORIGINS=http://localhost:5173,http://localhost:5174
JWT_SECRET=请替换为随机长字符串
JWT_EXPIRES_IN=7d

# 数据库
DATABASE_URL=mysql://root:password@127.0.0.1:3306/course_platform

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# 阿里云（OSS + 短信共用 AccessKey）
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
OSS_REGION=oss-cn-hangzhou
OSS_BUCKET=your-bucket-name

# 短信
ALIYUN_SMS_SIGN_NAME=你的签名
ALIYUN_SMS_TEMPLATE_CODE=SMS_xxxxxx

# 微信支付（Native 扫码）
WECHAT_APP_ID=
WECHAT_MCH_ID=
WECHAT_API_V3_KEY=
WECHAT_SERIAL_NO=
WECHAT_PRIVATE_KEY_PATH=./certs/apiclient_key.pem
WECHAT_PLATFORM_CERT_PATH=./certs/wechatpay_cert.pem
WECHAT_NOTIFY_URL=https://你的域名/api/payment/notify/wechat

# 支付宝（当面付 precreate）
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----
ALIPAY_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----
ALIPAY_GATEWAY=https://openapi.alipay.com/gateway.do
ALIPAY_NOTIFY_URL=https://你的域名/api/payment/notify/alipay

# 初始化管理员（seed 脚本用）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123456
